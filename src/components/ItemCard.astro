---
import type { Item } from '../lib/db';
import { LOCATIONS, LOCATION_LABELS } from '../lib/locations';
import { formatDa } from '../lib/dates';

interface Props {
  item: Item;
}
const { item } = Astro.props;

function expiresSoon(bb: string | null): boolean {
  if (!bb) return false;
  const today = new Date();
  const d = new Date(bb + 'T00:00:00Z');
  const diff = (d.getTime() - Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate())) / 86_400_000;
  return diff <= 3;
}
const soon = expiresSoon(item.best_before);
const qty = Number.isInteger(item.quantity) ? item.quantity : Number(item.quantity.toFixed(2));
---

<div class="card">
  <div class="row spread">
    <h3>{item.name}</h3>
    <span class="qty">{qty}</span>
  </div>

  <div class="row wrap" style="gap:0.4rem; margin:0.35rem 0 0.6rem;">
    {item.unit && <span class="tag">{item.unit}</span>}
    {item.category && <span class="tag">{item.category}</span>}
    {item.best_before && (
      soon
        ? <span class="badge-warn">Udløber snart · {formatDa(item.best_before)}</span>
        : <span class="tag">Bedst før {formatDa(item.best_before)}</span>
    )}
  </div>

  <div class="row" style="gap:0.4rem;">
    <form method="post" action="/api/inventory">
      <input type="hidden" name="action" value="consume" />
      <input type="hidden" name="id" value={item.id} />
      <button class="btn-sm" type="submit" title="Forbrug 1">− Forbrug</button>
    </form>

    <form method="post" action="/api/inventory" onsubmit="return confirm('Slet varen?')">
      <input type="hidden" name="action" value="delete" />
      <input type="hidden" name="id" value={item.id} />
      <button class="btn-sm btn-danger" type="submit" title="Slet">Slet</button>
    </form>
  </div>

  <details class="editor" style="margin-top:0.5rem;">
    <summary class="small">Redigér</summary>
    <form method="post" action="/api/inventory" style="margin-top:0.6rem;">
      <input type="hidden" name="action" value="update" />
      <input type="hidden" name="id" value={item.id} />
      <div class="field">
        <label>Navn</label>
        <input name="name" value={item.name} required />
      </div>
      <div class="grid-2">
        <div class="field">
          <label>Lokation</label>
          <select name="location">
            {LOCATIONS.map((l) => (
              <option value={l} selected={l === item.location}>{LOCATION_LABELS[l]}</option>
            ))}
          </select>
        </div>
        <div class="field">
          <label>Antal</label>
          <input name="quantity" type="number" min="0" step="1" value={qty} />
        </div>
      </div>
      <div class="grid-2">
        <div class="field">
          <label>Enhed</label>
          <input name="unit" value={item.unit ?? ''} placeholder="fx 500 g" />
        </div>
        <div class="field">
          <label>Kategori</label>
          <input name="category" value={item.category ?? ''} />
        </div>
      </div>
      <div class="field">
        <label>Bedst før (valgfri)</label>
        <input name="best_before" type="date" value={item.best_before ?? ''} />
      </div>
      <button class="btn-primary btn-block" type="submit">Gem ændringer</button>
    </form>
  </details>
</div>
