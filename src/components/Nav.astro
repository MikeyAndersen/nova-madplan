---
const path = Astro.url.pathname;

const links: { href: string; label: string }[] = [
  { href: '/', label: 'Forside' },
  { href: '/madplan', label: 'Madplan' },
  { href: '/madplan/arkiv', label: 'Arkiv' },
  { href: '/beholdning', label: 'Beholdning' },
  { href: '/priser', label: 'Priser' },
  { href: '/import', label: 'Import' },
];

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  if (href === '/madplan') return path === '/madplan';
  return path.startsWith(href);
}
---

<nav class="nav">
  <div class="nav-inner">
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
      ))}
    </div>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Skift lyst/mørkt tema" title="Skift tema">🌙</button>
  </div>
</nav>
