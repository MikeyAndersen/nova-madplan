---
import { env } from 'cloudflare:workers';
import Layout from '../../components/Layout.astro';
import MealCard from '../../components/MealCard.astro';
import { getCurrentWeek, getWeekWithMeals, listWeeks, type Meal } from '../../lib/db';
import { weekStatus, addDaysISO, dayMonthDa } from '../../lib/dates';

const db = env.DB;
const current = await getCurrentWeek(db);
const currentData = await getWeekWithMeals(db, current.id);

const all = await listWeeks(db);
const upcoming = all.filter((w) => weekStatus(w.start_date) === 'kommende');
const upcomingData = await Promise.all(upcoming.map((w) => getWeekWithMeals(db, w.id)));

const weeks = [currentData, ...upcomingData];

function rangeLabel(start: string): string {
  return `${dayMonthDa(start)} – ${dayMonthDa(addDaysISO(start, 6))}`;
}
function meal(meals: Meal[], weekday: number): Meal {
  return meals.find((m) => m.weekday === weekday)!;
}
---

<Layout title="Madplan">
  <h1>Madplan</h1>
  <p class="muted small">Denne uge og kommende uger. Markér en aften som fleks 🍳.</p>

  {weeks.map(({ week, meals }, idx) => (
    <section>
      <div class="section-head">
        <h2>
          Uge {week.week_no}
          {idx === 0 && <span class="tag" style="margin-left:0.4rem;">Denne uge</span>}
        </h2>
        <span class="count-pill">{rangeLabel(week.start_date)}</span>
      </div>

      <details class="quickfill" style="margin-bottom:0.9rem;">
        <summary class="btn btn-block">⚡ Hurtig udfyldning</summary>
        <form method="post" action="/api/meals" class="card" style="margin-top:0.6rem;">
          <input type="hidden" name="action" value="quickfill" />
          <input type="hidden" name="weekId" value={week.id} />
          <p class="small muted" style="margin-top:0;">
            Én linje pr. dag — fx <code>Mandag: hel kylling</code>. Dage du ikke nævner, røres ikke.
          </p>
          <textarea
            name="raw"
            rows="7"
            placeholder={'Mandag: hel kylling\nTirsdag: Sandwich (bagels)\nOnsdag: Salsiccia pasta\nTorsdag: rugbrød\nFredag: Lasagne\nLørdag: karry\nSøndag: Ramen eller karry'}
          ></textarea>
          <button class="btn-primary btn-block" type="submit" style="margin-top:0.5rem;">Udfyld ugen</button>
        </form>
      </details>

      <div class="cards">
        {[1, 2, 3, 4, 5, 6, 7].map((wd) => (
          <MealCard meal={meal(meals, wd)} dateISO={addDaysISO(week.start_date, wd - 1)} />
        ))}
      </div>
    </section>
  ))}

  <hr class="sep" />
  <form method="post" action="/api/meals">
    <input type="hidden" name="action" value="createUpcoming" />
    <button class="btn-primary btn-block" type="submit">+ Opret kommende uge</button>
  </form>
</Layout>
