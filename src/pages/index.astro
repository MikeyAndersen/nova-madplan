---
import { env } from 'cloudflare:workers';
import Layout from '../components/Layout.astro';
import MealCard from '../components/MealCard.astro';
import { getCurrentWeek, getWeekWithMeals, countByLocation, expiringSoon, type Meal } from '../lib/db';
import { addDaysISO } from '../lib/dates';
import { LOCATIONS, LOCATION_LABELS } from '../lib/locations';

const db = env.DB;
const current = await getCurrentWeek(db);
const { week, meals } = await getWeekWithMeals(db, current.id);
const counts = await countByLocation(db);
const expiring = await expiringSoon(db, 3);

function meal(weekday: number): Meal {
  return meals.find((m) => m.weekday === weekday)!;
}
const totalItems = Object.values(counts).reduce((a, b) => a + b, 0);
---

<Layout title="Oversigt">
  <h1>Madplan & Beholdning</h1>

  <div class="section-head">
    <h2>Denne uge · uge {week.week_no}</h2>
    <a class="count-pill" href="/madplan">Redigér →</a>
  </div>
  <div class="cards">
    {[1, 2, 3, 4, 5, 6, 7].map((wd) => (
      <MealCard meal={meal(wd)} dateISO={addDaysISO(week.start_date, wd - 1)} readOnly />
    ))}
  </div>

  <div class="section-head" style="margin-top:1.5rem;">
    <h2>Beholdning</h2>
    <a class="count-pill" href="/beholdning">Se alt →</a>
  </div>

  {expiring.length > 0 && (
    <a href="/beholdning" class="notice" style="display:block; text-decoration:none; color:inherit; border-color:var(--warn-ink);">
      ⚠️ {expiring.length} {expiring.length === 1 ? 'vare udløber' : 'varer udløber'} snart
    </a>
  )}

  <div class="stat-grid">
    {LOCATIONS.map((l) => (
      <a class="card stat" href={`/beholdning?location=${l}`}>
        <span class="stat-num">{counts[l]}</span>
        <span class="stat-label">{LOCATION_LABELS[l]}</span>
      </a>
    ))}
  </div>
  <p class="muted small" style="margin-top:0.5rem;">{totalItems} varer i alt.</p>
</Layout>

<style>
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.7rem;
  }
  @media (min-width: 34rem) {
    .stat-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-decoration: none;
    color: inherit;
    padding: 1rem 0.5rem;
  }
  .stat-num { font-size: 1.8rem; font-weight: 800; color: var(--accent); font-variant-numeric: tabular-nums; }
  .stat-label { font-size: 0.85rem; font-weight: 600; color: var(--muted); }
</style>
