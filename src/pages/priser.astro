---
import { env } from 'cloudflare:workers';
import Layout from '../components/Layout.astro';
import { listPrices } from '../lib/db';
import { summarizePrices, formatKr } from '../lib/prices';
import { formatDa } from '../lib/dates';

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
const rows = await listPrices(env.DB, q || undefined);
const items = summarizePrices(rows);
---

<Layout title="Priser">
  <h1>Prishistorik</h1>
  <p class="muted small">Stk-priser fra dine nemlig-importer.</p>

  <form class="toolbar" method="get">
    <input type="search" name="q" value={q} placeholder="Søg vare…" aria-label="Søg" />
    <button class="btn-primary" type="submit">Søg</button>
    {q && <a class="btn" href="/priser">Nulstil</a>}
  </form>

  {items.length === 0 && (
    <p class="empty">
      {q ? 'Ingen varer matcher.' : 'Ingen prisdata endnu — importér en nemlig-ordre, så dukker priserne op her.'}
    </p>
  )}

  <div class="cards" style="grid-template-columns:1fr;">
    {items.map((it) => (
      <div class="card">
        <div class="row spread">
          <h3>{it.name}</h3>
          <span class="qty">
            {formatKr(it.latest)}{it.unit && <span class="muted small"> / {it.unit}</span>}
          </span>
        </div>

        <div class="row wrap" style="gap:0.4rem; margin:0.35rem 0 0;">
          {it.change === 'up' && <span class="badge-up">▲ dyrere</span>}
          {it.change === 'down' && <span class="badge-down">▼ billigere</span>}
          {it.change === 'same' && <span class="tag">uændret</span>}
          <span class="tag">{it.points.length} {it.points.length === 1 ? 'køb' : 'køb'}</span>
          {it.points.length > 1 && (
            <span class="tag">Lavest {formatKr(it.min)} · Højest {formatKr(it.max)}</span>
          )}
        </div>

        {it.points.length > 1 && (
          <details class="editor" style="margin-top:0.5rem;">
            <summary class="small">Historik</summary>
            <ul class="price-list">
              {it.points.map((p) => (
                <li><span class="muted">{formatDa(p.date)}</span><span>{formatKr(p.price)}</span></li>
              ))}
            </ul>
          </details>
        )}
      </div>
    ))}
  </div>
</Layout>

<style>
  .badge-up,
  .badge-down {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
  }
  .badge-up { color: #9b2c20; background: #fbe6e3; }
  .badge-down { color: #2f6b46; background: #e7f1ea; }
  .price-list { list-style: none; padding: 0; margin: 0.5rem 0 0; }
  .price-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.35rem 0;
    border-top: 1px solid var(--border);
    font-variant-numeric: tabular-nums;
  }
</style>
