---
import { env } from 'cloudflare:workers';
import { COOKIE_NAME, COOKIE_MAX_AGE, signSession } from '../lib/auth';

const secret = env.SITE_PASSWORD;
let error = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const password = String(data.get('password') ?? '');
  if (password === secret) {
    const token = await signSession(secret);
    Astro.cookies.set(COOKIE_NAME, token, {
      httpOnly: true,
      sameSite: 'lax',
      secure: Astro.url.protocol === 'https:',
      path: '/',
      maxAge: COOKIE_MAX_AGE,
    });
    return Astro.redirect('/');
  }
  error = true;
}
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Log ind · Madplan</title>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f1ea; --card: #fff; --border: #e6e0d4; --ink: #2b2724; --sub: #5c5349;
        --field-bg: #fbfaf6; --field-border: #d8d0c2;
        --accent: #a25415; --accent-active: #874711; --accent-ink: #fff;
        --err-bg: #fbe6e3; --err-ink: #9b2c20;
        --shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          color-scheme: dark;
          --bg: #1b1916; --card: #252220; --border: #3a352f; --ink: #ece7dd; --sub: #a59c8e;
          --field-bg: #2b2825; --field-border: #3a352f;
          --accent: #e08a4d; --accent-active: #c9743a; --accent-ink: #1b1916;
          --err-bg: #3a2420; --err-ink: #f0a59c;
          --shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
        }
      }
      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #1b1916; --card: #252220; --border: #3a352f; --ink: #ece7dd; --sub: #a59c8e;
        --field-bg: #2b2825; --field-border: #3a352f;
        --accent: #e08a4d; --accent-active: #c9743a; --accent-ink: #1b1916;
        --err-bg: #3a2420; --err-ink: #f0a59c;
        --shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100dvh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        background: var(--bg);
        color: var(--ink);
      }
      .card {
        width: 100%;
        max-width: 22rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 1.75rem 1.5rem;
        box-shadow: var(--shadow);
      }
      h1 { font-size: 1.35rem; margin: 0 0 0.25rem; }
      p.sub { margin: 0 0 1.25rem; color: var(--sub); font-size: 0.95rem; }
      label { display: block; font-size: 0.9rem; margin-bottom: 0.4rem; font-weight: 600; }
      input {
        width: 100%;
        padding: 0.85rem 0.9rem;
        font-size: 1rem;
        border: 1px solid var(--field-border);
        border-radius: 0.6rem;
        background: var(--field-bg);
        color: var(--ink);
      }
      input:focus { outline: 2px solid var(--accent); border-color: var(--accent); }
      button {
        margin-top: 1rem;
        width: 100%;
        padding: 0.9rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--accent-ink);
        background: var(--accent);
        border: none;
        border-radius: 0.6rem;
        cursor: pointer;
      }
      button:active { background: var(--accent-active); }
      .error {
        margin: 0 0 1rem;
        padding: 0.6rem 0.8rem;
        background: var(--err-bg);
        color: var(--err-ink);
        border-radius: 0.5rem;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <form class="card" method="post" autocomplete="off">
      <h1>Madplan & Beholdning</h1>
      <p class="sub">Indtast kodeord for at fortsætte.</p>
      {error && <p class="error">Forkert kodeord. Prøv igen.</p>}
      <label for="password">Kodeord</label>
      <input
        id="password"
        name="password"
        type="password"
        inputmode="text"
        autofocus
        required
      />
      <button type="submit">Log ind</button>
    </form>
  </body>
</html>
