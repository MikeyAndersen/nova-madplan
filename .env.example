# nova-madplan — kopiér til .env og udfyld secrets (INTEGRATION_SPEC §6).
# OBS: .env-ændringer på serveren kræver `docker compose down && up -d` (spec §0.3).

# ── Fase 1 (aktive nu) ────────────────────────────────────────────────
DATABASE_PATH=/data/madplan.db
LIFEHUB_API_TOKEN=            # brain → madplan auth; SAMME værdi i lifehub/.env
TIMEZONE=Europe/Copenhagen

# ── Fase 4: forslags-motor + brain-lager ──────────────────────────────
# NB: brain lytter på 8300 (spec §6 skrev 8000 — rettet jf. §8).
BRAIN_URL=http://brain:8300
INTERNAL_API_TOKEN=           # madplan → brain inventory; SAMME værdi i lifehub/.env
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
STRONG_OLLAMA_MODEL=qwen2.5:32b-instruct   # Fase 5 (32b-pass)
INVENTORY_POLL_MINUTES=15
#SUGGEST_HARD_DAYS=14         # §4.3 hård udelukkelse
#SUGGEST_SOFT_DAYS=7          # §4.3 blødt loft ved <7 kandidater
#FUZZY_RATIO=0.85             # §4.2 ingrediens-match
#SUGGEST_AUTO=true            # false slår poll/cron/cooked-triggere fra

# ── Fase 5: 32b-drain ─────────────────────────────────────────────────
MADPLAN_DRAIN_TOKEN=          # agent → madplan drain (openssl rand -hex 32)
# PC'ens Ollama set fra madplan-containeren (tunnel/LAN). Tom = PC utilgængelig
# (drain svarer online:false, 7b-sættet forbliver aktivt).
STRONG_OLLAMA_URL=
#SUGGEST_QUEUE_MAX_DAYS=7     # §5 hård grænse for kø-poster
